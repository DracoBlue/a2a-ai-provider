{
  "name": "a2a-ai-provider",
  "version": "0.5.0-alpha.0",
  "description": "Community A2A provider for the ai-sdk from vercel",
  "homepage": "https://github.com/dracoblue/a2a-ai-provider",
  "repository": {
    "type": "git",
    "url": "https://github.com/dracoblue/a2a-ai-provider.git",
    "directory": "."
  },
  "license": "MIT",
  "author": "DracoBlue <JanS@DracoBlue.de> (https://dracoblue.net)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm",
    "test": "vitest --run",
    "test:update": "vitest -u",
    "test:watch": "vitest -w",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [
    "ai",
    "vercel-ai",
    "ai-sdk"
  ],
  "peerDependencies": {
    "ai": ">=5.0.0 <7.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/provider-utils": "^4.0.28",
    "@ai-sdk/react": "^3.0.204",
    "@ai-sdk/test-server": "^1.0.5",
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.9",
    "@vitest/coverage-v8": "^3.2.6",
    "ai": "^6.0.202",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.6",
    "zod": "^4.1.12"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13"
  }
}
